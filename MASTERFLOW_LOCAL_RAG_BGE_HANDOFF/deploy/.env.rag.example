RAG_ENABLED=false
RAG_HOST=127.0.0.1
RAG_PORT=8091
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=masterflow

EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
MODEL_DEVICE=auto
MODEL_CACHE_DIR=/models

RAG_CANDIDATE_LIMIT=20
RAG_RESULT_LIMIT=6
RAG_CONTEXT_TOKEN_BUDGET=3500
RAG_CONTEXT_TOKEN_HARD_MAX=6000
RAG_REQUIRE_PERMISSION_FILTER=true
RAG_ALLOW_UNSCOPED_GODMODE_DEBUG=false
