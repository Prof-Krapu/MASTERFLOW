# L'instance alpha reste privee par defaut : le port Docker est lie a localhost.
MASTERFLOW_BIND=127.0.0.1
MASTERFLOW_HTTP_PORT=8080

# Copier le SHA du commit effectivement livre, jamais le SHA d'une branche theorique.
MASTERFLOW_RELEASE_SHA=REPLACE_WITH_DEPLOYED_GIT_SHA

# Secrets de production : ne jamais conserver les vraies valeurs dans Git.
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=30d
GODMODE_USERNAME=owner
GODMODE_PASSWORD=REPLACE_WITH_A_STRONG_PRIVATE_PASSWORD

# Alpha sure : le LLM reste mock tant qu'un provider n'a pas ete explicitement active.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_EGRESS_ALLOWLIST=
