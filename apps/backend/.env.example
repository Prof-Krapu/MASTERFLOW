# MasterFlow backend — variables d'environnement.
# Copier en `.env` et ajuster. Le `.env` est gitignored.

NODE_ENV=development
PORT=8000

# SHA exact du commit réellement publié. S'il est absent, le cockpit D12 affiche
# honnêtement « version live non vérifiée » au lieu d'inférer l'état depuis Git.
MASTERFLOW_RELEASE_SHA=

# Secret de signature JWT (>= 32 chars en prod). En dev, un fallback est utilisé si absent.
JWT_SECRET=change-me-please-32-chars-minimum-secret
JWT_EXPIRES_IN=30d

# Compte godmode seedé au boot (sinon défauts dev : vincent / masterflow).
GODMODE_USERNAME=vincent
GODMODE_PASSWORD=masterflow

# LLM — laisser provider=mock pour développer sans clé (réponses simulées, AUCUN réseau).
# provider réels : openai | mistral | gemini | groq | albert | openrouter (OpenAI-compat).
#
# OpenRouter = fournisseur LLM par défaut du projet (gateway multi-modèles : 1 clé /
# 1 base URL, N modèles). Le ROUTAGE par tâche (chat/ocr/correction/image…) et par RÔLE
# (prof/admin → modèle plus fort, économie de tokens) est porté par la table
# `task_model_profiles` — des profils VALIDÉS sont déjà seedés au boot.
#
# ⇒ INTERRUPTEUR RÉEL : tant que LLM_PROVIDER=mock, tout est INERTE (zéro appel externe,
#   même avec les profils seedés). Passer en live = renseigner les 4 lignes ci-dessous
#   avec une vraie clé OpenRouter (jamais commitée). Pour activer :
#     LLM_PROVIDER=openrouter
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_API_KEY=sk-or-…              (secret, hors Git)
#     LLM_EGRESS_ALLOWLIST=https://openrouter.ai
#   LLM_MODEL ci-dessous = modèle GLOBAL de repli si un profil n'en déclare pas ;
#   les modèles par tâche/rôle vivent dans les profils (voir db/seed.ts).
# NB image : la génération d'image reste derrière le gate GO IMAGE (action sensible) ;
#   sortie runner en needs_review, jamais completed. ComfyUI éventuel = local-only.
#
# DeepSeek (TEST local, OpenAI-compat) — déviation du défaut OpenRouter pour brancher une IA
#   réelle rapidement. Modèle texte unique `deepseek-chat` (pas de vision/OCR ni d'image). Le seed
#   bascule automatiquement les profils sur le provider `deepseek` quand LLM_PROVIDER=deepseek :
#   penser à re-seeder (`npm run seed`) avec ce `.env` chargé. Pour activer :
#     LLM_PROVIDER=deepseek
#     LLM_BASE_URL=https://api.deepseek.com
#     LLM_API_KEY=sk-…                  (secret, hors Git)
#     LLM_MODEL=deepseek-chat
#     LLM_EGRESS_ALLOWLIST=https://api.deepseek.com
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# Origines exactes autorisées, séparées par des virgules. Obligatoire hors mock.
# Exemple : https://openrouter.ai  (ou https://api.openai.com,https://api.mistral.ai)
LLM_EGRESS_ALLOWLIST=

# ComfyUI local (génération d'image, OPTIONNEL, local-only, 1 job GPU à la fois).
# Laisser vide pour ne pas activer la voie ComfyUI. Doit être une origine loopback.
COMFYUI_BASE_URL=
# Identité/cadence du runner image (défauts raisonnables si absent).
IMAGE_RUNNER_ID=image-runner-local
IMAGE_RUNNER_LEASE_MS=300000
IMAGE_RUNNER_POLL_MS=3000

# Runner OCR — racine locale où sont résolues les références storage:// (lecture seule).
MASTERFLOW_STORAGE_ROOT=./data/storage
# Taille max d'une image source (octets). Défaut : 15 Mo.
MASTERFLOW_STORAGE_MAX_BYTES=15728640
# Identité/cadence du runner OCR (défauts raisonnables si absent).
OCR_RUNNER_ID=ocr-runner-local
OCR_RUNNER_LEASE_MS=300000
OCR_RUNNER_POLL_MS=3000
