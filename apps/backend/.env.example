# MasterFlow backend — variables d'environnement.
# Copier en `.env` et ajuster. Le `.env` est gitignored.

NODE_ENV=development
PORT=8000

# Secret de signature JWT (>= 32 chars en prod). En dev, un fallback est utilisé si absent.
JWT_SECRET=change-me-please-32-chars-minimum-secret
JWT_EXPIRES_IN=30d

# Compte godmode seedé au boot (sinon défauts dev : vincent / masterflow).
GODMODE_USERNAME=vincent
GODMODE_PASSWORD=masterflow

# LLM — laisser provider=mock pour développer sans clé (réponses simulées).
# provider réels : openai | mistral | gemini | groq | albert (OpenAI-compat).
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
