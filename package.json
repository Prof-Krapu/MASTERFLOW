{
  "name": "masterflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MasterFlow — OS pédagogique à personas fusionnables (client MALEX). Monorepo backend-first.",
  "workspaces": [
    "apps/backend",
    "packages/shared",
    "packages/poc-frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/backend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:poc": "npm run dev --workspace @masterflow/poc-frontend",
    "seed": "npm run seed --workspace apps/backend",
    "test": "npm run test --workspace apps/backend",
    "lint": "npm run lint --workspace apps/backend"
  }
}
